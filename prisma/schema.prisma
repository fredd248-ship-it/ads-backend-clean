generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  createdAt DateTime   @default(now())

  decisions Decision[]
}

model Decision {
  id              String   @id @default(uuid())
  title           String
  category        String?
  cost            Float?
  timePressure    Int?
  emotionalWeight Int?
  createdAt       DateTime @default(now())

  // 🔴 CRITICAL — USER OWNERSHIP
  userId          String
  user            User     @relation(fields: [userId], references: [id])

  evaluations     Evaluation[]
}

model Evaluation {
  id              String   @id @default(uuid())
  decisionId      String
  regretScore     Int
  frequencyOfUse  String
  wouldBuyAgain   Boolean
  timePressure    Int?
  emotionalWeight Int?
  createdAt       DateTime @default(now())

  decision        Decision @relation(fields: [decisionId], references: [id])
}